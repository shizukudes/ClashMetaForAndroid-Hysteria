+
+type udpOverTCPPacketConn struct {
+	net.Conn
+}
+
+func (uc *udpOverTCPPacketConn) WriteTo(b []byte, addr net.Addr) (n int, err error) {
+	// Parse alamat SOCKS5 yang diberikan oleh router Clash
+	socksAddr := socks5.ParseAddrToSocksAddr(addr)
+	if len(socksAddr) < 4 {
+		return 0, errors.New("invalid socks addr length")
+	}
+
+	var flags uint8 = 0
+	var udpgwAddr []byte
+
+	// 0x01 = IPv4, 0x04 = IPv6
+	if socksAddr[0] == 0x01 {
+		udpgwAddr = socksAddr[1:7] // 4 bytes IP + 2 bytes Port
+	} else if socksAddr[0] == 0x04 {
+		flags |= 0x08 // UDPGW_CLIENT_FLAG_IPV6
+		udpgwAddr = socksAddr[1:19] // 16 bytes IP + 2 bytes Port
+	} else {
+		return 0, errors.New("unsupported address type for udpgw")
+	}
+
+	// Buat udpgw_header (BadVPN protocol)
+	// 1 byte flags, 2 bytes conid (LittleEndian)
+	udpgwHeader := make([]byte, 3)
+	udpgwHeader[0] = flags
+	binary.LittleEndian.PutUint16(udpgwHeader[1:], 0) // conid = 0
+
+	// Kalkulasi PacketProto (BadVPN stream framing)
+	packetLen := len(udpgwHeader) + len(udpgwAddr) + len(b)
+	
+	// BadVPN selalu menggunakan LittleEndian untuk 2-byte panjang paket
+	lenHeader := make([]byte, 2)
+	binary.LittleEndian.PutUint16(lenHeader, uint16(packetLen))
+
+	// Tembakkan ke server 7300
+	if _, err = uc.Conn.Write(lenHeader); err != nil {
+		return
+	}
+	if _, err = uc.Conn.Write(udpgwHeader); err != nil {
+		return
+	}
+	if _, err = uc.Conn.Write(udpgwAddr); err != nil {
+		return
+	}
+	n, err = uc.Conn.Write(b)
+	return len(b), err
+}
+
+func (uc *udpOverTCPPacketConn) ReadFrom(b []byte) (int, net.Addr, error) {
+	// Baca panjang dari PacketProto BadVPN (LittleEndian)
+	lenHeader := make([]byte, 2)
+	if _, err := io.ReadFull(uc.Conn, lenHeader); err != nil {
+		return 0, nil, err
+	}
+	packetLen := binary.LittleEndian.Uint16(lenHeader)
+
+	if packetLen < 3 {
+		return 0, nil, errors.New("udpgw packet too short")
+	}
+
+	packet := make([]byte, packetLen)
+	if _, err := io.ReadFull(uc.Conn, packet); err != nil {
+		return 0, nil, err
+	}
+
+	flags := packet[0]
+	// conid = packet[1:3] - tidak perlu dicek karena ini client
+	offset := 3
+
+	var ip net.IP
+	var port int
+
+	// Parse udpgw_addr_ipv6 vs udpgw_addr_ipv4
+	if (flags & 0x08) != 0 {
+		if len(packet) < offset+18 {
+			return 0, nil, errors.New("udpgw ipv6 packet truncated")
+		}
+		ip = net.IP(packet[offset : offset+16])
+		port = int(binary.BigEndian.Uint16(packet[offset+16 : offset+18]))
+		offset += 18
+	} else {
+		if len(packet) < offset+6 {
+			return 0, nil, errors.New("udpgw ipv4 packet truncated")
+		}
+		ip = net.IP(packet[offset : offset+4])
+		port = int(binary.BigEndian.Uint16(packet[offset+4 : offset+6]))
+		offset += 6
+	}
+
+	payload := packet[offset:]
+	copy(b, payload)
+
+	udpAddr := &net.UDPAddr{IP: ip, Port: port}
+	return len(payload), udpAddr, nil
+}
+
+func (uc *udpOverTCPPacketConn) LocalAddr() net.Addr {
+	return uc.Conn.LocalAddr()
+}
